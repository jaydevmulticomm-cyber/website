# Example environment variables
# Copy this file to .env.local and update with your values.
# .env.local is ignored by git.

# Webhook URL to forward quote requests (e.g., Zapier, Make, or a custom endpoint)
QUOTE_WEBHOOK_URL=

# Optional: SendGrid API key if you plan to integrate email notifications
SENDGRID_API_KEY=

# Optional: Airtable API key / base if storing leads in Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Quotes
