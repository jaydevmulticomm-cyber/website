# Example environment variables
# Copy this file to .env.local and update with your values.
# .env.local is ignored by git.

# ─── RFQ email notification (PRIMARY — required to receive quote emails) ───
# Resend API key. Reuse the one from the old site's Render env vars.
RESEND_API_KEY=
# Inbox that receives RFQ notifications.
NOTIFICATION_EMAIL=sales@jaydevmulticomm.com
# Sender. The domain (jaydevmulticomm.com) must be VERIFIED in Resend.
NOTIFICATION_FROM_EMAIL=Jaydev Multicomm <noreply@jaydevmulticomm.com>

# ─── Airtable lead tracking (every RFQ also creates a row in the Inquiries table) ───
# Create a Personal Access Token at airtable.com/create/tokens with
# scopes: data.records:write  +  access to the base below.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appCwf2U4SqPCMigw
AIRTABLE_TABLE_NAME=tblwuvHw71jB0oHD9

# ─── Optional extra webhook (Zapier / Make / Google Sheets) — leave blank if unused ───
QUOTE_WEBHOOK_URL=
